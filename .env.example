# ─────────────────────────────────────────────────────────────
# Larnova company site — copy to `.env.local` and fill in.
# Set production values in Netlify → Site settings → Environment variables.
# ─────────────────────────────────────────────────────────────

# Magic-link admin login (Resend — https://resend.com).
# Without RESEND_API_KEY, sign-in links are logged to the server console.
RESEND_API_KEY=
# Verified sender. Domain must be verified in Resend.
EMAIL_FROM="Larnova <noreply@larnova.co>"

# Comma-separated admin emails that can manage the site (jobs, etc.).
# Any @larnova.co address is always an admin.
COMPANY_ADMIN_EMAILS=

# Canonical site origin for magic-link URLs, e.g. https://larnova.co
# If unset, it's derived from the request host.
SITE_URL=

# Newsletter (optional) — adds subscribers to a Resend Audience.
RESEND_AUDIENCE_ID=

# Netlify Blobs (data store) needs no config on Netlify / `netlify dev`.
# Under plain `next dev` it falls back to a local JSON store in `.company-data/`.
